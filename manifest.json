{
  "manifest_version": "0.3",
  "name": "uspto-patents-pp-mcp",
  "display_name": "Open Data Portal",
  "version": "4.2.0",
  "description": "Open Data Portal API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/uspto-patents-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/uspto-patents-pp-mcp",
      "args": [],
      "env": {
        "USPTO_API_KEY": "${user_config.uspto_api_key}"
      }
    }
  },
  "user_config": {
    "uspto_api_key": {
      "type": "string",
      "title": "USPTO_API_KEY",
      "description": "Sets USPTO_API_KEY for the Open Data Portal MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
